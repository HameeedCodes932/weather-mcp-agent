GROQ_API_KEY=your_groq_api_key_here

# SMTP Email — for send_email tool (optional)
# Option A — Gmail: https://myaccount.google.com/apppasswords (needs 2SV)
# Option B — Brevo: https://brevo.com (free, 300 emails/day, no 2SV)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_brevo_smtp_login
SMTP_PASSWORD=your_smtp_key
SMTP_FROM=your_sender_email@example.com
